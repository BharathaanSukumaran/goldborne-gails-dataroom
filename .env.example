# Backend
# Local default. For production SQLite, use an absolute persisted path such as sqlite:////data/dataroom.sqlite.
DATABASE_URL=sqlite:///backend/dataroom.sqlite

# Server-side only. Configure in Netlify environment variables for deploys; leave blank locally to disable synthesis.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
USE_OPENAI_SYNTHESIS=false

# Frontend
# Safe to expose. The browser uses this to call the FastAPI service.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
