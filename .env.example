# Default is deterministic/no-spend. Set ASSISTANT_USE_LLM=true only when you want model synthesis.
ASSISTANT_USE_LLM=false
LLM_PROVIDER=deterministic
MODEL_NAME=

# Paid/API-backed options. Do not commit real keys.
OPENAI_API_KEY=
GEMINI_API_KEY=

# Free local option: install Ollama and run `ollama pull llama3.2:3b`.
# Then set LLM_PROVIDER=ollama and ASSISTANT_USE_LLM=true.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
