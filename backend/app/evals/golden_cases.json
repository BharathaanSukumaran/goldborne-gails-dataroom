      "expect": {
        "answer_type_any_of": [
          "financial",
          "structured",
          "unknown"
        ],
        "requires_citations": true,
        "forbid_approximation_words": true,
        "forbid_unsupported_money": true,
        "financial_metrics": [
          {
            "metric": "debt",
            "mode": "unknown_until_extracted"
          }
        ]
      }
    },
    {
      "id": "private_covenants_unknown",
      "question": "What are the company's private banking covenants and headroom?",
      "expect": {
        "answer_type_any_of": [
          "unknown"
        ],
        "requires_unknown": true,
        "requires_missing_information": true,
        "forbid_unsupported_money": true,
        "must_not_contain": [
          "comfortable headroom",
          "no covenant risk"
        ]
      }
    },
    {
      "id": "charge_holder_0006",
      "question": "Who holds charge 0006?",
      "expect": {
        "answer_type_any_of": [
          "charges_security",
          "charges",
          "structured"
        ],
        "requires_citations": true,
        "must_contain": [
          "Glas Trust Corporation Limited"
        ],
        "must_not_contain": [
          "0605 5393 0005"
        ],
        "charge_field": {
          "field_intent": "charge_holder",
          "resolved_charge_code": "060553930006",
          "expected_source_id": "ch-charge-0006",
          "must_contain": [
            "Glas Trust Corporation Limited"
          ],
          "forbid_generic_charge_list": true
        }
      }
    },
    {
      "id": "charge_status_0005",
