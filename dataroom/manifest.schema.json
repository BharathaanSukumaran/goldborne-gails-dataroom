{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://goldborne.local/dataroom/manifest.schema.json",
  "title": "Goldborne Gail's Dataroom Source Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "company",
    "coverage",
    "sources"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "company": {
      "type": "object",
      "required": [
        "legal_name",
        "company_number",
        "jurisdiction"
      ],
      "additionalProperties": false,
      "properties": {
        "legal_name": {
          "type": "string"
        },
        "company_number": {
          "type": "string"
        },
        "jurisdiction": {
          "type": "string"
        },
        "companies_house_url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "coverage": {
      "type": "object",
      "required": [
        "required_categories",
        "covered_categories",
        "known_gaps"
      ],
      "additionalProperties": false,
      "properties": {
        "required_categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "covered_categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "known_gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "title",
          "category",
          "issuer",
          "retrieved_at",
          "source_url",
          "local_path",
          "included_reason",
          "processing_status"
        ],
        "additionalProperties": false,
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "title": {
            "type": "string"
          },
          "category": {
            "enum": [
              "company_profile",
              "filing_history",
              "accounts",
              "charges",
              "management",
              "ownership",
              "news"
            ]
          },
          "issuer": {
            "type": "string"
          },
          "retrieved_at": {
            "type": "string",
            "format": "date-time"
          },
          "source_url": {
            "type": "string",
            "format": "uri"
          },
          "local_path": {
            "type": "string"
          },
          "included_reason": {
            "type": "string"
          },
          "processing_status": {
            "enum": [
              "pending_download",
              "pending_manual_curation",
              "downloaded",
              "processed",
              "verified"
            ]
          },
          "expected_file": {
            "type": [
              "string",
              "null"
            ]
          },
          "filing_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "filed_at": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "period_end": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "pages": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
