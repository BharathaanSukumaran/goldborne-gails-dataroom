{
  "cases": [
    {
      "id": "brief_revenue_ebitda_exact_or_unknown",
      "question": "What was revenue and EBITDA in the last reported year?",
      "expect": {
        "answer_type_any_of": [
          "financial",
          "structured",
          "unknown"
        ],
        "requires_citations": true,
        "forbid_approximation_words": true,
        "forbid_unsupported_money": true,
        "financial_metrics": [
          {
            "metric": "revenue",
            "mode": "unknown_until_extracted"
          },
          {
            "metric": "ebitda",
            "mode": "unknown_until_extracted"
          }
        ]
      }
    },
    {
      "id": "brief_charges_have_holder_status_and_sources",
      "question": "What charges are registered against the company and who holds them?",
      "expect": {
        "answer_type_any_of": [
          "charges",
          "charges_security",
          "structured",
          "unknown"
        ],
        "requires_citations": true,
        "must_not_contain": [
          "no charges",
          "none registered"
        ]
      }
    },
    {
      "id": "brief_lender_risks_are_sourced_or_unknown",
      "question": "What are the key risks for a lender?",
      "expect": {
        "answer_type_any_of": [
          "retrieval",
          "hybrid",
          "narrative",
          "credit_summary",
          "unknown"
        ],
        "requires_citations": true,
        "forbid_approximation_words": true
      }
    },
    {
      "id": "brief_credit_summary_is_sourced_or_unknown",
      "question": "Draft a short credit summary of the business.",
      "expect": {
        "answer_type_any_of": [
          "retrieval",
          "hybrid",
          "narrative",
          "credit_summary",
          "unknown"
